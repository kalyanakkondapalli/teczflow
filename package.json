{
  "name": "teczflow",
  "version": "1.0.0",
  "private": true,
  "description": "TeczFlow — AI-native API Intelligence Platform by MyTecz",
  "workspaces": [
    "packages/*",
    "ui"
  ],
  "scripts": {
    "build": "npm run build -w @teczflow/core && npm run build -w @teczflow/mcp-server && npm run build -w @teczflow/cli && npm run build -w @teczflow/ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "npm run start -w @teczflow/mcp-server",
    "cli": "npm run start -w @teczflow/cli",
    "ui:dev": "npm run dev -w @teczflow/ui",
    "ui:build": "npm run build -w @teczflow/ui",
    "ui:api": "node scripts/ui-api.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
